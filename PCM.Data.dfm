  object qry_ChartKontaktart: TFDQuery
    Connection = con_PCM
    SQL.Strings = (
      
        'SELECT '#39'Privat'#39',COUNT(*)  AS  Wert,Cast(ID_benutzer AS UNSIGNED ' +
        ') AS ID_Benutzer  FROM manager_kontakte WHERE ID_kontaktart = 1'
      'Union ALL '
      
        'SELECT '#39'Gesch'#228'ftlich'#39',COUNT(*)  AS Wert ,Cast(ID_benutzer AS UNS' +
        'IGNED ) AS ID_Benutzer FROM manager_kontakte WHERE ID_kontaktart' +
        ' = 2'
      'Union ALL '
      
        'SELECT '#39'Privat u. Gesch'#228'ftlich'#39',COUNT(*)  AS Wert ,Cast(ID_benut' +
        'zer AS UNSIGNED ) AS ID_Benutzer FROM manager_kontakte WHERE ID_' +
        'kontaktart = 3'
      'Union ALL '
      
        'SELECT '#39'Sonstige'#39',COUNT(*)  AS Wert,Cast(ID_benutzer AS UNSIGNED' +
        ' ) AS ID_Benutzer  FROM manager_kontakte WHERE ID_kontaktart = 4'
      '')
    Left = 1032
    Top = 24
  end
  object ds_ChartKontaktart: TDataSource
    DataSet = qry_ChartKontaktart
    Left = 1032
    Top = 108
  end
  object qry_ChartAdressen: TFDQuery
    Connection = con_PCM
    SQL.Strings = (
      
        'SELECT '#39'Privat'#39',COUNT(*)  AS  Wert,Cast(ID_benutzer AS UNSIGNED ' +
        ') AS ID_Benutzer  FROM manager_kontakte WHERE Firma = '#39#39' OR Firm' +
        'a IS null'
      'Union ALL '
      
        'SELECT '#39'Gesch'#228'ftlich'#39',COUNT(*)  AS Wert ,Cast(ID_benutzer AS UNS' +
        'IGNED ) AS ID_Benutzer FROM manager_kontakte WHERE Firma <> '#39#39
      '')
    Left = 1164
    Top = 24
  end
