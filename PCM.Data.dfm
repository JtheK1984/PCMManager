object dm_PCM: Tdm_PCM
  OnCreate = DataModuleCreate
  Height = 1196
  Width = 1703
  PixelsPerInch = 144
  object con_PCM: TFDConnection
    Params.Strings = (
      'Database=pcm'
      'User_Name=root'
      'Password=pcm'
      'Server=127.0.0.1'
      'Port=3307'
      'DriverID=MySQL')
    ResourceOptions.AssignedValues = [rvAutoReconnect]
    ResourceOptions.AutoReconnect = True
    Connected = True
    LoginPrompt = False
    BeforeConnect = con_PCMBeforeConnect
    Left = 48
    Top = 12
  end
  object qry_ChartKalender: TFDQuery
    Connection = con_PCM
    SQL.Strings = (
      ''
      
        'SELECT '#39'heute'#39',COUNT(*)  AS Wert,Cast(ID_benutzer AS UNSIGNED ) ' +
        'AS ID_Benutzer FROM manager_kalender WHERE DATE(Finish) = Date(N' +
        'OW()) AND Time(Finish) >= Time(NOW()) '
      'Union ALL '
      
        'SELECT '#39'morgen'#39',COUNT(*)  AS Wert,Cast(ID_benutzer AS UNSIGNED )' +
        ' AS ID_Benutzer FROM manager_kalender WHERE DATE(Finish) = Date(' +
        'NOW()+1) '
      'Union ALL '
      
        'SELECT '#39#252'berf'#228'llig'#39',COUNT(*)  AS Wert,Cast(ID_benutzer AS UNSIGN' +
        'ED ) AS ID_Benutzer FROM manager_kalender WHERE Finish < NOW()')
    Left = 479
    Top = 24
  end
  object qry_ChartKategorie: TFDQuery
    Connection = con_PCM
    SQL.Strings = (
      
        'SELECT IFNULL(maa.Bezeichnung,'#39'keine'#39') AS Kategorie ,Count(mak.I' +
        'D_IC_Aufgabenarten) as Wert, ID_Benutzer '
      'FROM manager_kalender mak'
      
        'LEFT OUTER JOIN manager_aufgaben_arten maa ON maa.ID = mak.ID_IC' +
        '_Aufgabenarten'
      'WHERE mak.ID_IC_Aufgabenarten IS NOT NULL'
      'GROUP BY mak.ID_IC_Aufgabenarten'
      'ORDER BY Kategorie')
    Left = 641
    Top = 24
  end
  object ds_ChartKategorie: TDataSource
    DataSet = qry_ChartKategorie
    Left = 641
    Top = 108
  end
  object ds_ChartKalender: TDataSource
    DataSet = qry_ChartKalender
    Left = 479
    Top = 108
  end
  object ds_ChartAufgabe: TDataSource
    DataSet = qry_ChartAufgabe
    Left = 168
    Top = 108
  end
  object qry_ChartAufgabe: TFDQuery
    Connection = con_PCM
    SQL.Strings = (
      ''
      
        'SELECT '#39'ungelesen'#39',COUNT(*)  AS  Wert,Cast(ID_benutzer AS UNSIGN' +
        'ED ) AS ID_Benutzer  FROM manager_kalender WHERE Bearbeitetam IS' +
        ' NULL and GelesenAM IS  NULL and Typ IN (0,1) AND finish >= NOW(' +
        ')'
      'Union ALL '
      
        'SELECT '#39'gelesen'#39',COUNT(*)  AS Wert ,Cast(ID_benutzer AS UNSIGNED' +
        ' ) AS ID_Benutzer FROM manager_kalender WHERE Bearbeitetam IS NU' +
        'LL and GelesenAM IS not NULL and Typ IN (0,1) AND finish >= NOW(' +
        ')'
      'Union ALL '
      
        'SELECT '#39#252'berf'#228'llig'#39',COUNT(*)  AS Wert ,Cast(ID_benutzer AS UNSIG' +
        'NED ) AS ID_Benutzer FROM manager_kalender WHERE Bearbeitetam IS' +
        ' NULL and Typ IN (0,1) AND finish < NOW()'
      'Union ALL '
      
        'SELECT '#39'bearbeitet'#39',COUNT(*)  AS Wert,Cast(ID_benutzer AS UNSIGN' +
        'ED ) AS ID_Benutzer  FROM manager_kalender WHERE Bearbeitetam IS' +
        ' not NULL'
      '')
    Left = 168
    Top = 24
  end
  object FDPhysADSDriverLink1: TFDPhysADSDriverLink
    Left = 1428
    Top = 252
  end
  object FDPhysMSSQLDriverLink1: TFDPhysMSSQLDriverLink
    Left = 1260
    Top = 252
  end
  object qry_ChartFinance: TFDQuery
    Connection = con_PCM
    SQL.Strings = (
      
        'SELECT '#39'Einnahmen'#39' AS Bezeichung,  SUM(Betrag) AS Ist, SUM(Fixbe' +
        'trag) AS Soll,ID_Benutzer FROM manager_finanzen_einnahmen'
      'union all '
      
        'SELECT '#39'variable Ausgaben'#39', SUM(Betrag) AS Ist, SUM(Fixbetrag) A' +
        'S Soll ,ID_Benutzer FROM manager_finanzen_ausgaben  Where Fixkos' +
        'ten = '#39'false'#39' and Gueltig_Monat = Month(Now()) and Gueltig_Jahr ' +
        '= Year(Now())'
      'union ALL '
      
        'SELECT '#39'Fixkosten fix'#39',SUM(Betrag) AS Ist, SUM(Fixbetrag) AS Sol' +
        'l,ID_Benutzer FROM manager_finanzen_ausgaben Where Fixkosten = '#39 +
        'true'#39)
    Left = 323
    Top = 24
  end
  object ds_ChartFinance: TDataSource
    DataSet = qry_ChartFinance
    Left = 323
    Top = 108
  end
  object ds_Kalender_Filter: TDataSource
    DataSet = qry_Kalender_Filter
    Left = 312
    Top = 770
  end
  object qry_Kalender_Filter: TFDQuery
    Active = True
    Connection = con_PCM
    SQL.Strings = (
      'Select DISTINCT Kalendername FROM manager_Kalender '
      'ORDER BY Kalendername')
    Left = 312
    Top = 686
  end
