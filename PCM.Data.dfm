  object FDQuery1: TFDQuery
    Connection = con_PCM
    SQL.Strings = (
      ''
      
        'SELECT '#39'ungelesen'#39',COUNT(*)  AS  Wert,Cast(ID_benutzer AS UNSIGN' +
        'ED ) AS ID_Benutzer  FROM manager_kalender WHERE Bearbeitetam IS' +
        ' NULL and GelesenAM IS  NULL and Typ IN (0,1) AND finish >= NOW(' +
        ')'
      'Union ALL '
      
        'SELECT '#39'gelesen'#39',COUNT(*)  AS Wert ,Cast(ID_benutzer AS UNSIGNED' +
        ' ) AS ID_Benutzer FROM manager_kalender WHERE Bearbeitetam IS NU' +
        'LL and GelesenAM IS not NULL and Typ IN (0,1) AND finish >= NOW(' +
        ')'
      'Union ALL '
      
        'SELECT '#39#252'berf'#228'llig'#39',COUNT(*)  AS Wert ,Cast(ID_benutzer AS UNSIG' +
        'NED ) AS ID_Benutzer FROM manager_kalender WHERE Bearbeitetam IS' +
        ' NULL and Typ IN (0,1) AND finish < NOW()'
      'Union ALL '
      
        'SELECT '#39'bearbeitet'#39',COUNT(*)  AS Wert,Cast(ID_benutzer AS UNSIGN' +
        'ED ) AS ID_Benutzer  FROM manager_kalender WHERE Bearbeitetam IS' +
        ' not NULL'
      '')
    Left = 612
    Top = 192
  end
