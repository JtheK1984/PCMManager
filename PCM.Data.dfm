    Left = 1164
    Top = 108
  end
  object qry_ChartGeburtstage: TFDQuery
    Connection = con_PCM
    SQL.Strings = (
      'Select Count(*) as Wert, Month(Geburtsdatum) as Monat, '
      'case Month(Geburtsdatum) '
      'when 1 then '#39'Januar'#39' '
      'when 2 then '#39'Februar'#39' '
      'when 3 then '#39'M'#228'rz'#39' '
      'when 4 then '#39'April'#39' '
      'when 5 then '#39'Mai'#39' '
      'when 6 then '#39'Juni'#39' '
      'when 7 then '#39'Juli'#39' '
      'when 8 then '#39'August'#39' '
      'when 9 then '#39'September'#39' '
      'when 10 then '#39'Oktober'#39' '
      'when 11 then '#39'November'#39' '
      'ELSE '#39'Dezember'#39
      'END AS Monatbes, '
      'Cast(ID_benutzer AS UNSIGNED ) AS ID_Benutzer'
      'From manager_kontakte '
      'Where Geburtsdatum is not null'
      'Group by Month(Geburtsdatum)'
      'Order by Monat ASC'
      '')
    Left = 1296
    Top = 24
  end
  object ds_ChartGeburtstage: TDataSource
    DataSet = qry_ChartGeburtstage
    Left = 1296
    Top = 108
  end
  object qry_ChartPWDSerials: TFDQuery
    Connection = con_PCM
    SQL.Strings = (
      
        'Select Count(*) as Wert, '#39'Passw'#246'rter'#39'  as BEZ,Cast(ID_benutzer A' +
        'S UNSIGNED ) AS ID_Benutzer  From manager_passwoerter '
      'UNION ALL'
      
        'Select Count(*) as Wert, '#39'Serials'#39'  as BEZ ,Cast(ID_benutzer AS ' +
        'UNSIGNED ) AS ID_Benutzer From manager_Serials ')
    Left = 1416
    Top = 24
  end
